# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/upstream

# Encryption key for API credentials (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# NextAuth
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your_nextauth_secret_here

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Daytona API
DAYTONA_API_KEY=your_daytona_api_key
DAYTONA_API_URL=https://app.daytona.io/api

# Cron secret for scheduled job endpoints (required in production, optional in development)
# CRON_SECRET=your_cron_secret_here

# -----------------------------------------------------------------------------
# MCP servers — see packages/web/MCP_SETUP.md for full setup steps
# -----------------------------------------------------------------------------

# Smithery (registry browsing + remote MCP connections via Smithery Connect)
# Get a key at https://smithery.ai/console/api-keys
SMITHERY_API_KEY=your_smithery_api_key
SMITHERY_NAMESPACE=

GITHUB_APP_ID=your_github_app_id
GITHUB_APP_SLUG=your_github_app_slug
# PEM — single line with literal \n between rows (quotes required).
# Convert with: awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' your-key.pem
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
