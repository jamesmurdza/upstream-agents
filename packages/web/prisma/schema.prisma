generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// User - linked to GitHub OAuth
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  githubId      String?   @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Admin flag for analytics dashboard access
  isAdmin Boolean @default(false)

  // Pro subscription flag for unlimited shared Claude usage
  isPro Boolean @default(false)

  // JSONB for flexible settings storage (no migrations needed for new fields)
  // { defaultAgent, defaultModel, theme }
  settings Json?

  // JSONB for encrypted credentials (no migrations needed for new keys)
  // { anthropicApiKey, anthropicAuthToken, openaiApiKey, opencodeApiKey, geminiApiKey }
  credentials Json?

  // JSONB for encrypted repository-level environment variables
  // { "owner/repo": { "KEY1": "encrypted_value1", ... }, ... }
  repoEnvironmentVariables Json?

  // GitHub App installation id, captured in the install callback. Null until
  // the user installs our GitHub App. Used to mint short-lived installation
  // access tokens at agent-run time so the agent can call GitHub's MCP server
  // with properly-scoped credentials.
  githubAppInstallationId String?

  chats         Chat[]
  accounts      Account[]
  sessions      Session[]
  activityLogs  ActivityLog[]
  scheduledJobs ScheduledJob[]
  skills        Skill[]
}

// =============================================================================
// NextAuth.js required tables
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// Chat - server-owned resource with server-generated IDs
// =============================================================================

model Chat {
  id     String @id @default(cuid())
  userId String

  // Repo config (immutable after first message)
  repo       String // "owner/repo" or "__new__"
  baseBranch String @default("main")

  // Sandbox-related fields (synced cloud resources)
  branch              String? // Git branch name created for this chat
  sandboxId           String? // Daytona sandbox ID
  sessionId           String? // Agent session ID for conversation continuity
  previewUrlPattern   String? // URL pattern for dev server previews
  backgroundSessionId String? // Active execution ID (for recovery)

  // Agent config
  agent           String  @default("opencode")
  model           String?
  planModeEnabled Boolean @default(false)

  // Display
  displayName String?
  status      String  @default("pending") // pending, creating, ready, running, error

  // Branching support
  parentChatId String?
  parentChat   Chat?   @relation("ChatBranches", fields: [parentChatId], references: [id], onDelete: SetNull)
  childChats   Chat[]  @relation("ChatBranches")

  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime @default(now())

  // Sync flag for git pull on next execution
  needsSync Boolean @default(false)

  // JSONB for encrypted chat-level environment variables
  // { "KEY1": "encrypted_value1", ... }
  environmentVariables Json?

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  mcpServers ChatMcpServer[]

  // Link back to scheduled run (if this chat belongs to one)
  scheduledJobRun ScheduledJobRun?

  @@index([userId, updatedAt])
  @@index([userId, lastActiveAt])
}

// =============================================================================
// ChatMcpServer - per-chat MCP connections (via Smithery Connect)
// =============================================================================
// Each row is one connected MCP server for a specific chat. The agent in the
// sandbox will get a config entry pointing at `mcpUrl` with `encryptedApiKey`
// decrypted into an Authorization header.

model ChatMcpServer {
  id     String @id @default(cuid())
  chatId String

  // Identity from Smithery's registry
  qualifiedName String // e.g. "exa/exa-search" — stable handle
  displayName   String
  iconUrl       String?

  // Smithery Connect connection details. Null for non-Smithery rows (e.g. the
  // GitHub MCP row, which goes directly to api.githubcopilot.com).
  smitheryConnectionId String?
  smitheryNamespace    String?
  mcpUrl               String // remote MCP endpoint the agent will call

  // Encrypted Smithery API key used to call mcpUrl. Stored per-row so that
  // rotating the global key doesn't silently break existing connections.
  encryptedApiKey String? @db.Text

  // Lifecycle
  status    String  @default("pending") // pending | connected | error
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, qualifiedName])
  @@index([chatId])
}

// =============================================================================
// Message - server-generated IDs, ordered by timestamp
// =============================================================================

model Message {
  id     String @id @default(cuid())
  chatId String

  role      String // "user" | "assistant"
  content   String  @db.Text
  timestamp BigInt // Unix timestamp in milliseconds

  // Which agent/model produced this message (nullable for old messages)
  agent String?
  model String?

  // Optional fields
  messageType String? // "chat" | "git-operation"
  isError     Boolean @default(false)

  // JSONB for complex nested data (avoids separate tables)
  toolCalls     Json? // Array<{ tool, summary, fullSummary?, output? }>
  contentBlocks Json? // Array<ContentBlock>
  uploadedFiles Json? // Array<string> - file paths

  // Git operation message fields
  linkBranch String?

  // Flexible metadata for actions, links, etc.
  // { action?: "force-push" | "view-pr" | "view-branch", prUrl?: string, ... }
  metadata Json?

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, timestamp])
  @@index([chatId, id])
}

// =============================================================================
// CcAuthInfo - kv blobs managed by ccauth + /api/cron/refresh-claude-creds
// =============================================================================
// Two well-known rows:
//   id="claude-cookies":     { value: "<claude.ai cookies JSON>" }
//   id="claude-credentials": { value: '{"claudeAiOauth":{...}}' }
// Stored as text (not JSONB) — we hand the raw string to the agent's
// CLAUDE_CODE_CREDENTIALS env var without re-serializing.

model CcAuthInfo {
  id        String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// =============================================================================
// ActivityLog - tracks user actions for admin analytics
// =============================================================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // "login" | "logout" | "chat_created" | "chat_deleted" | "message_sent" | "settings_updated" | "admin_promoted" | "admin_demoted"
  metadata  Json? // Flexible payload: { chatId, targetUserId, repo, model, etc. }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// ScheduledJob - Automated agent runs on a schedule
// =============================================================================

model ScheduledJob {
  id     String @id @default(cuid())
  userId String

  // Config
  name       String
  prompt     String  @db.Text
  repo       String // "owner/repo"
  baseBranch String
  agent      String
  model      String?

  // Trigger configuration
  triggerType     String  @default("interval") // "interval" | "webhook"
  githubWebhookId Int?    // GitHub's webhook ID (for cleanup on delete)
  webhookSecret   String? // HMAC secret for verifying webhook payloads

  // Schedule (used when triggerType = "interval")
  intervalMinutes Int // e.g., 360 = every 6 hours
  enabled         Boolean  @default(true)
  nextRunAt       DateTime

  // Auto-PR
  autoPR Boolean @default(true)

  // Continue from last run
  continueFromLastRun Boolean @default(false)

  // Failure tracking
  consecutiveFailures Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs ScheduledJobRun[]

  @@index([userId])
  @@index([enabled, nextRunAt])
}

// =============================================================================
// ScheduledJobRun - Each execution of a scheduled job
// =============================================================================

model ScheduledJobRun {
  id    String @id @default(cuid())
  jobId String

  // Execution
  status      String // "pending" | "running" | "completed" | "error"
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Trigger context (for webhook-triggered runs)
  // { workflowName, workflowUrl, branch, commitSha, failedAt }
  triggerContext Json?

  // Results
  sandboxId           String?
  backgroundSessionId String?
  branch              String?
  baseBranch          String? // The branch this run was created from
  commitCount         Int     @default(0)
  prUrl               String?
  prNumber            Int?
  error               String? @db.Text

  // Link to chat for full message history
  chatId String? @unique
  chat   Chat?   @relation(fields: [chatId], references: [id])

  job ScheduledJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, startedAt])
  @@index([status])
}

// =============================================================================
// Skill - repo-scoped skill manifests
// =============================================================================

model Skill {
  id        String   @id @default(cuid())
  userId    String
  repo      String   // "owner/repo" — which repo this skill belongs to

  // Skill identity
  publisher  String  // e.g. "anthropic", "vercel"
  name       String  // e.g. "code-review"
  fullHandle String  // "publisher/name" — the install handle

  // Source
  url        String? // Source URL (skills.sh link)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repo, fullHandle])
  @@index([userId, repo])
}
